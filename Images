<!DOCTYPE html>  
<html lang="en">  
<head>  
<meta charset="UTF-8">  
<meta name="viewport" content="width=device-width, initial-scale=1.0">  
<title>Gallery | Kevin Deon Norton</title>  
<style>  
    body { font-family: sans-serif; background-color: #1a1a1a; color: #f4f4f4; margin: 0; padding: 40px; text-align: center; }  
    h1 { color: #cca43b; text-transform: uppercase; letter-spacing: 2px; }  
    .nav { margin-bottom: 40px; }  
    .nav a { color: #ccc; text-decoration: none; margin: 0 15px; font-weight: bold; }  
    .nav a:hover { color: #cca43b; }  
      
    .gallery-grid {  
        display: grid;  
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));  
        gap: 15px;  
        max-width: 1200px;  
        margin: 0 auto;  
    }  
    .gallery-item {  
        background: #333;  
        border-radius: 8px;  
        overflow: hidden;  
        border: 1px solid #444;  
    }  
    .gallery-item img {  
        width: 100%;  
        height: 250px;  
        object-fit: cover;  
        display: block;  
        transition: transform 0.3s;  
    }  
    .gallery-item img:hover { transform: scale(1.05); }  
    .caption { padding: 10px; font-size: 0.9rem; color: #bbb; }  
</style>  
</head>  
<body>

    <div class="nav">  
        <a href="index.html">← Home</a>  
        <a href="about.html">Bio</a>  
    </div>

    <h1>Visual Legacy</h1>  
    <p>Stills from the set, the stage, and the boardroom.</p>

    <div class="gallery-grid">  
        <!-- IMAGE 1 -->  
        <div class="gallery-item">  
            <img src="https://via.placeholder.com/400x300" alt="Kevin Deon Film Set">  
            <div class="caption">Directing on Set</div>  
        </div>

        <!-- IMAGE 2 -->  
        <div class="gallery-item">  
            <img src="https://via.placeholder.com/400x300" alt="Tulsa Flood Performance">  
            <div class="caption">Tulsa Flood Live</div>  
        </div>

        <!-- IMAGE 3 -->  
        <div class="gallery-item">  
            <img src="https://via.placeholder.com/400x300" alt="BQC Consulting">  
            <div class="caption">Brubaker Quality Control</div>  
        </div>  
          
        <!-- Add more here by copying the 'gallery-item' block -->  
    </div>

</body>  
</html> 
